# Copy this file to .env and fill in your real values
DATABASE_URL=mysql+pymysql://root:password@localhost/insurance_db
SECRET_KEY=change-me-to-a-long-random-string
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM provider: "groq" or "ollama"
LLM_PROVIDER=groq

# Ollama (used when LLM_PROVIDER=ollama or when per-request override selects ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=180

# Google Sheets integration (optional)
# Option A — path to service account JSON file:
# GOOGLE_SERVICE_ACCOUNT_JSON=C:\path\to\service-account.json
# Option B — raw JSON string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional — auto-share every exported sheet with this email:
# GOOGLE_SHEETS_SHARE_EMAIL=your-email@gmail.com
